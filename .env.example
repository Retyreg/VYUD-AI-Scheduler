# Copy this file to .env and fill in your actual values.
# .env is gitignored and must never be committed with real credentials.

# Groq AI (https://console.groq.com)
GROQ_API_KEY=your-groq-api-key-here

# Telegram Bot (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# LinkedIn (https://www.linkedin.com/developers/)
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token-here
LINKEDIN_PROFILE_ID=your-linkedin-profile-id-here

# Flask API base URL used by auto_post.py (default: http://127.0.0.1:5000)
# Change this if your Flask server runs on a different host/port
FLASK_API_URL=http://127.0.0.1:5000

# Database backend (optional)
# Leave blank to use local SQLite (posts.db) — good for development.
# Set to a PostgreSQL URL to use Supabase or any Postgres instance:
#   postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Supabase example:
#   postgresql://postgres:your-password@db.xxxxxxxxxxxx.supabase.co:5432/postgres
DATABASE_URL=
