# Copy this file to .env and fill in your actual values.
# .env is gitignored and must never be committed with real credentials.

# Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google AI (Gemini)
GOOGLE_AI_API_KEY=AIza...

# Groq
GROQ_API_KEY=gsk_...

# HuggingFace
HUGGINGFACE_API_KEY=hf_...

# Replicate (images)
REPLICATE_API_TOKEN=r8_...

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token-here

# LinkedIn
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token-here

# VK
VK_ACCESS_TOKEN=your-vk-access-token-here

# TGStat (Telegram analytics)
TGSTAT_API_KEY=your-tgstat-api-key-here

# CORS allowed origins (comma-separated, e.g. https://publisher.vyud.tech)
ALLOWED_ORIGINS=http://localhost:3000,https://publisher.vyud.tech
